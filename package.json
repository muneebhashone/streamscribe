{
  "name": "chrome-mic-channel-recorder",
  "version": "1.0.0",
  "description": "Bun + TypeScript terminal audio app that streams browser/system audio and microphone audio as separate Deepgram live STT channels.",
  "type": "module",
  "bin": {
    "audio-recorder": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun src/cli.ts live",
    "live": "bun src/cli.ts live",
    "record": "bun src/cli.ts record",
    "devices": "bun src/cli.ts devices",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun test && tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
